<Window x:Class="LotusCyberSecurityBot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lotus Cybersecurity Awareness Bot"
        Height="650"
        Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#121212">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0"
                Background="#2A002A"
                CornerRadius="12"
                Padding="10">

            <StackPanel>
                <TextBlock Text="LOTUS"
                           Foreground="#FF4DFF"
                           FontSize="32"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Cybersecurity Awareness Assistant"
                           Foreground="White"
                           FontSize="14"
                           HorizontalAlignment="Center"/>


            </StackPanel>
        </Border>

        <!-- CHAT AREA -->
        <Grid Grid.Row="1" Margin="10">

            <!-- FULL SIZE BACKGROUND LAYER -->
            <Grid>

                <!-- ANIMATED ASCII BACKGROUND -->
                <TextBlock x:Name="AsciiBackground"
                   Text=
                            
"_       ____  _______  _    _   _____
| |     / __ \ |__  __ | |  | | / ____|
| |    | |  | |  | |   | |  | |  (___
| |    | |  | |  | |   | |  | | \___ \
| |___ | |__| |  | |   | |__| | ____)
|______ \____/   |_|    \____/ |_____/"
                   FontFamily="Consolas"
                   FontSize="36"
                   Foreground="#50CCCCCC"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   LineHeight="18"
                   Margin="59,68,63,49"
                   IsHitTestVisible="False"
                   Opacity="0.12"/>

            </Grid>

            <!-- FOREGROUND CHAT LAYER -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                <StackPanel x:Name="ChatPanel"/>

            </ScrollViewer>

        </Grid>

        <!-- INPUT AREA -->
        <Grid Grid.Row="2" Margin="10">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="140"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInputTextBox"
                     Grid.Column="0"
                     FontSize="15"
                     Padding="10"
                     Background="#333333"
                     Foreground="White"
                     BorderBrush="#D100D1"
                     BorderThickness="2"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown"/>

            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Content="Send"
                    Background="#D100D1"
                    Foreground="White"
                    FontWeight="Bold"
                    Click="SendButton_Click"/>
        </Grid>

    </Grid>
</Window>

